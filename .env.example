SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# Optional. Used by `npm run spotify:token`.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/callback

# Firebase Web SDK — public app identifiers, used client-side for Analytics only.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# Firebase Admin SDK — service-account credentials, SERVER ONLY. Never exposed
# to the client. From the service-account JSON (Project settings → Service
# accounts → Generate new private key). Keep the quotes around the private key
# so the literal "\n" newlines survive.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Shared secret protecting /api/syncSpotify. Vercel Cron sends it automatically
# as `Authorization: Bearer ${CRON_SECRET}`; manual calls use ?secret=...
CRON_SECRET=