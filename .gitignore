# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local assistant/editor state
.agents/
.codex/
.claude/

# raw/reference assets
/p3rfonts/
/p3ruis/
/Persona 3 Reload*.mp4

# source copies; app serves the committed copies from /public/p3r
/hoversoundeffect.wav
/onclick.wav

# raw P3R asset dump
# Keep only the moon atlas currently imported by the calendar HUD.
/UI/*
!/UI/Field/
/UI/Field/*
!/UI/Field/Day/
/UI/Field/Day/*
!/UI/Field/Day/T_UI_Field_Day_00_texture.png
